    <action>
      <name>Ajustes Gold</name>
      <description/>
      <type>SQL</type>
      <attributes/>
      <connection>MySQL local bronze</connection>
      <sendOneStatement>N</sendOneStatement>
      <sql>delete from data_gold.f_tickets;
delete from data_gold.rel_servicio_torre;
delete from data_gold.d_entorno;
delete from data_gold.d_estado;
delete from data_gold.d_prioridad;
delete from data_gold.d_servicio;
delete from data_gold.d_sla;
delete from data_gold.d_tiposervicio;
delete from data_gold.d_torre;

insert into data_gold.d_entorno values (-1, 'Sin entorno', 'Sin entorno');
insert into data_gold.d_estado values (-1, 'Sin estado', 'Sin estado');
insert into data_gold.d_prioridad values (-1, 'Sin prioridad');
insert into data_gold.d_servicio values (-1, 'Sin servicio');
insert into data_gold.d_sla values (-1, 'Sin SLA');
insert into data_gold.d_tiposervicio values (-1, 'Sin tipo de servicio');
insert into data_gold.d_torre values (-1, 'Sin torre');</sql>
      <sqlfromfile>N</sqlfromfile>
