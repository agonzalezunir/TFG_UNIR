    <action>
      <name>Ajustes Silver</name>
      <description/>
      <type>SQL</type>
      <attributes/>
      <connection>MySQL local bronze</connection>
      <sendOneStatement>N</sendOneStatement>
      <sql>update data_silver.tickets
set clasentorno='Producción' where entorno like '%Production%' and entorno not like '%Not Production$';

update data_silver.tickets
set clasentorno='No Producción' where entorno not like '%Production%' and entorno like '%Not Production$';

update data_silver.tickets
set clasestado='Abierto' where estado in ('Asignado', 'Pendiente');

update data_silver.tickets
set clasestado='Cerrado' where estado in ('Cerrado', 'Resuelto');

delete from data_silver.tickets where estado='Cancelado';
delete from data_silver.tickets where tipodeservicio='Evento de infraestructura';
delete from data_silver.tickets where fechacreacion is null;

update data_silver.tickets
set clastiposervicio = 'Petición' where tipodeservicio in ('Petición de serv. por el usuario');

update data_silver.tickets
set clastiposervicio = 'Incidencia' where tipodeservicio in ('Restauración de servicio a usuario', 'Restauración de infraestructura');



update data_silver.tickets set prioridad='Alta' where prioridad='Crítica' and clasentorno='No Producción';
update data_silver.tickets set prioridad='Alta' where prioridad='Crítica' and clastiposervicio='Petición';



</sql>
      <sqlfilename/>
      <sqlfromfile>N</sqlfromfile>
      <useVariableSubstitution>N</useVariableSubstitution>
